# ==============================================================================
# Cenar Store Bot - Mẫu biến môi trường
# ------------------------------------------------------------------------------
# Copy file này thành .env (Store 1) hoặc .env.store2 (Store 2) rồi điền giá trị.
# TUYỆT ĐỐI KHÔNG commit .env / .env.store2 chứa giá trị thật lên git.
# Các biến đánh dấu [BẮT BUỘC] phải có, còn lại có giá trị mặc định trong code.
# ==============================================================================

# ── Discord Bot [BẮT BUỘC] ────────────────────────────────────────────────────
# BOT_TOKEN: token bot Discord (Developer Portal > Bot > Reset Token)
BOT_TOKEN=YOUR_BOT_TOKEN
# CLIENT_ID: Application ID (Developer Portal > General Information)
CLIENT_ID=YOUR_CLIENT_ID
# GUILD_ID: ID server Discord để đăng ký slash command
GUILD_ID=YOUR_GUILD_ID
# STORE_NAME: tên hiển thị của shop
STORE_NAME=Cenar Store

# ── HTTP / API nội bộ ─────────────────────────────────────────────────────────
# HTTP_PORT: cổng server nội bộ (Store 1 dùng 5000, Store 2 dùng 8080)
HTTP_PORT=5000
# BOT_API_KEY: khóa chung giữa website Next.js và bot API (server-to-server).
#   Website phải gửi header x-bot-api-key khớp giá trị này. Sinh chuỗi ngẫu nhiên
#   đủ dài, ví dụ: cnr_<hex 48 ký tự>. KHÔNG dùng lại khóa đã lộ.
BOT_API_KEY=YOUR_BOT_API_KEY
# DASHBOARD_ENABLED / DASHBOARD_TOKEN: dashboard mini nội bộ
DASHBOARD_ENABLED=true
DASHBOARD_TOKEN=YOUR_DASHBOARD_TOKEN

# ── Mã hóa dữ liệu nhạy cảm [BẮT BUỘC] ────────────────────────────────────────
# ENCRYPTION_KEY: 64 ký tự hex (32 byte). Cả 2 store PHẢI dùng CHUNG một khóa vì
#   dùng chung DB. Sinh bằng: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   LƯU Ý: đổi khóa này sẽ làm KHÔNG giải mã được credential đã lưu trước đó.
ENCRYPTION_KEY=YOUR_64_CHAR_HEX_KEY

# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_PATH: đường dẫn file SQLite. Store 1 để mặc định, Store 2 dùng file riêng.
DATABASE_PATH=./data/shopbot.sqlite

# ── PayOS - Thanh toán [BẮT BUỘC nếu PAYMENT_PROVIDER=PAYOS] ──────────────────
PAYMENT_PROVIDER=PAYOS
PAYOS_CLIENT_ID=YOUR_PAYOS_CLIENT_ID
PAYOS_API_KEY=YOUR_PAYOS_API_KEY
PAYOS_CHECKSUM_KEY=YOUR_PAYOS_CHECKSUM_KEY
# PUBLIC_BASE_URL [BẮT BUỘC]: domain công khai để PayOS gọi webhook/return/cancel.
PUBLIC_BASE_URL=https://your-domain.example
# Đường dẫn webhook/return/cancel (có mặc định, thường không cần đổi).
PAYOS_WEBHOOK_PATH=/webhooks/payos
PAYOS_RETURN_PATH=/payments/payos/return
PAYOS_CANCEL_PATH=/payments/payos/cancel
# TRANSCRIPT_BASE_URL (tùy chọn): domain riêng cho link transcript, để trống -> gửi kèm file.
# TRANSCRIPT_BASE_URL=https://api.your-domain.example

# ── VietQR fallback (dùng khi guild chưa /setup-bank) ─────────────────────────
VIETQR_BANK_BIN=970418
VIETQR_ACCOUNT_NO=
VIETQR_ACCOUNT_NAME=CENAR STORE

# ── AI trợ lý (tùy chọn) ──────────────────────────────────────────────────────
# GROQ_API_KEY hoặc OPENROUTER_API_KEY: để trống nếu không dùng tính năng AI.
GROQ_API_KEY=
# GEMINI_API_KEYS: danh sách key ngăn cách dấu phẩy (nếu dùng Gemini).
GEMINI_API_KEYS=

# ── Backup Telegram (tùy chọn nhưng nên có) ───────────────────────────────────
# Tạo bot mới qua @BotFather, lấy token; lấy chat_id nơi nhận file backup.
# Nếu để trống, chức năng gửi backup qua Telegram sẽ bị bỏ qua.
TELEGRAM_BACKUP_TOKEN=
TELEGRAM_BACKUP_CHAT_ID=

# ── Backup Google Drive (tùy chọn) ────────────────────────────────────────────
# Service account của Google Cloud (dùng cho backup lên Drive).
GD_CLIENT_EMAIL=
# GD_PRIVATE_KEY: dùng \n cho ký tự xuống dòng, bọc trong dấu nháy kép.
GD_PRIVATE_KEY=
GD_FOLDER_ID=

# ── Cenar Hub / liên kết chuyển server (tùy chọn) ─────────────────────────────
# CENAR_HUB_URL / CENAR_HUB_TOKEN: dùng cho lệnh /chuyen-server giữa các store.
CENAR_HUB_URL=
CENAR_HUB_TOKEN=
# CENAR_HUB_SILENT: đặt true để tắt log Hub.
CENAR_HUB_SILENT=false

# ── Website / OAuth / CORS (tùy chọn) ─────────────────────────────────────────
# WEBSITE_URL: URL website chính (dùng trong một số link).
WEBSITE_URL=
# CLIENT_SECRET: Discord OAuth secret (nếu dùng đăng nhập web qua Discord).
CLIENT_SECRET=
# CORS_ALLOWED_ORIGINS: danh sách origin được phép, ngăn cách dấu phẩy.
CORS_ALLOWED_ORIGINS=
# GITHUB_REPO_URL: dùng cho luồng tự cập nhật/backup (nếu có).
GITHUB_REPO_URL=

# ── Cờ nội bộ tiến trình con (KHÔNG chỉnh tay) ────────────────────────────────
# IS_CHILD_BOT / ENV_FILE do launcher tự set khi chạy đa store bằng PM2.
